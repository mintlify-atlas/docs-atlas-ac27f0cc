  "keyFeatures": [
    "ACID-compliant transactions with MVCC (Multi-Version Concurrency Control)",
    "Advanced SQL support including window functions, CTEs, and lateral joins",
    "Powerful full-text search with configurable text search dictionaries",
    "Flexible JSON/JSONB support for document storage alongside relational data",
    "Streaming and logical replication for high availability and data distribution",
    "Extensible type system with user-defined types, functions, operators, and index methods",
    "Robust partitioning with declarative range, list, and hash partitioning",
    "Foreign Data Wrappers (FDW) for querying external data sources",
    "Multiple procedural languages: PL/pgSQL, PL/Python, PL/Perl, PL/Tcl",
    "Point-in-Time Recovery (PITR) and comprehensive backup tooling",
    "Row-level security (RLS) and fine-grained access control",
    "JIT compilation for complex analytical queries"
  ],
  "publicApiSurface": [
    "libpq C client library API",
    "SQL: SELECT, INSERT, UPDATE, DELETE, MERGE",
    "SQL DDL: CREATE/ALTER/DROP TABLE, INDEX, SEQUENCE, VIEW, MATERIALIZED VIEW",
    "SQL: CREATE FUNCTION / PROCEDURE (PL/pgSQL, PL/Python, PL/Perl, PL/Tcl, C)",
    "SQL: CREATE EXTENSION",
    "SQL: CREATE FOREIGN DATA WRAPPER / SERVER / USER MAPPING",
    "System catalogs: pg_class, pg_attribute, pg_proc, pg_index, etc.",
    "Information schema views",
    "psql CLI client",
    "pg_dump / pg_restore backup utilities",
    "pg_ctl server control utility",
    "pg_basebackup physical backup tool",
    "pg_upgrade major version upgrade tool",
    "initdb cluster initialization utility",
    "pgbench benchmarking tool",
    "pg_stat_statements extension",
    "SPI (Server Programming Interface) for C extensions",
    "Generic WAL API for custom resource managers",
    "Table Access Method API",
    "Index Access Method API"
  ]
}
